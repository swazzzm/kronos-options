# ══════════════════════════════════════════════════════════════════════
#  Kronos Options Signal System — Environment Variables
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── Upstox (primary broker) ───────────────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=https://127.0.0.1/callback
# Access token is short-lived (1 day). Set after daily login flow.
UPSTOX_ACCESS_TOKEN=your_bearer_token_here

# ── Zerodha (fallback broker — stub implementation) ───────────────────
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token_here

# ── Kronos model ──────────────────────────────────────────────────────
# Path to where you cloned https://github.com/shiyu-coder/Kronos
# Setup: git clone https://github.com/shiyu-coder/Kronos C:\path\to\Kronos
#        cd C:\path\to\Kronos && pip install -r requirements.txt
# HuggingFace models (NeoQuasar/Kronos-small etc.) download automatically on first run.
KRONOS_REPO_PATH=C:\path\to\Kronos

# ── Live trading kill switch ──────────────────────────────────────────
# Must be "true" (exact string) AND --live CLI flag AND typed confirmation.
# Leave as "false" for paper trading.
LIVE_TRADING=false
