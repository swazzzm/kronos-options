# ══════════════════════════════════════════════════════════════════════
#  Kronos Options Signal System — Environment Variables
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── Zerodha Kite Connect (primary broker) ───────────────────────────────
# Get api_key and api_secret from https://developers.kite.trade/apps
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here

# Access token is refreshed daily by zerodha_auth.py — do not set manually
ZERODHA_ACCESS_TOKEN=

# Required for automated (TOTP) token refresh via zerodha_auth.py
# ZERODHA_USER_ID: your Zerodha client ID (e.g. AB1234)
# ZERODHA_PASSWORD: your Zerodha login password
# ZERODHA_TOTP_SECRET: the TOTP base32 secret shown when you set up
#   2FA on Zerodha (Settings > Security > TOTP). This is NOT the 6-digit code.
#   It looks like: JBSWY3DPEHPK3PXP
ZERODHA_USER_ID=your_client_id_here
ZERODHA_PASSWORD=your_password_here
ZERODHA_TOTP_SECRET=your_totp_base32_secret_here

# ── Upstox (kept for backtester — expired option data API) ───────────────
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=https://127.0.0.1/callback
UPSTOX_ACCESS_TOKEN=your_bearer_token_here

# ── Kronos model ─────────────────────────────────────────────────────────
# Path to where you cloned https://github.com/shiyu-coder/Kronos
# Setup: git clone https://github.com/shiyu-coder/Kronos C:\path\to\Kronos
#        cd C:\path\to\Kronos && pip install -r requirements.txt
KRONOS_REPO_PATH=C:\path\to\Kronos

# ── Live trading kill switch ────────────────────────────────────────────
# Must be "true" (exact string) AND --live CLI flag AND typed confirmation.
# Leave as "false" for paper trading.
LIVE_TRADING=false
