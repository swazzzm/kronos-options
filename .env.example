# ══════════════════════════════════════════════════════════════════════
# Kronos Options — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── Active broker (must match broker.primary in config.yaml) ──────────
# Set ONLY the keys for the broker you are using.

# ── Upstox ────────────────────────────────────────────────────────────
# Get from: https://login.upstox.com → My Apps → Access Token (refresh daily)
UPSTOX_ACCESS_TOKEN=

# ── Zerodha (leave blank if using Upstox) ─────────────────────────────
# API key from: https://kite.trade → My Apps
ZERODHA_API_KEY=
# API secret from: https://kite.trade → My Apps
ZERODHA_API_SECRET=
# Access token — must be generated each morning via Kite Connect login flow.
# Run: python src/broker/zerodha.py  (after implementing login flow)
ZERODHA_ACCESS_TOKEN=

# ── Kronos model ──────────────────────────────────────────────────────
# Absolute path to the cloned https://github.com/shiyu-coder/Kronos repo
# Overrides repo_path in config.yaml if set.
KRONOS_REPO_PATH=

# ── Live trading safety gate ──────────────────────────────────────────
# Must be exactly "true" (lowercase) to allow live_trader.py to run.
# Leave blank or set to "false" to keep all trading in paper mode.
LIVE_TRADING=false
