# ══════════════════════════════════════════════════════════════════════════
# Kronos Options — Environment Variables  (Zerodha setup)
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════

# ── Zerodha Kite Connect ──────────────────────────────────────────────────
# API key from: https://kite.trade → My Apps → API Key
ZERODHA_API_KEY=

# API secret from: https://kite.trade → My Apps → API Secret
ZERODHA_API_SECRET=

# Access token — must be regenerated EVERY MORNING via Kite Connect login flow.
# Steps each morning:
#   1. Open browser: https://kite.zerodha.com/connect/login?api_key=YOUR_API_KEY
#   2. Login → get request_token from redirect URL
#   3. Run: python src/broker/zerodha.py --generate-token YOUR_REQUEST_TOKEN
#   4. Paste the printed access_token below
ZERODHA_ACCESS_TOKEN=

# ── Kronos model ─────────────────────────────────────────────────────────
# Absolute path to the cloned https://github.com/shiyu-coder/Kronos repo
# Overrides repo_path in config.yaml if set.
KRONOS_REPO_PATH=

# ── Live trading safety gate ──────────────────────────────────────────────
# Must be exactly "true" (lowercase) to allow live_trader.py to run.
# Leave as "false" at all times for paper trading.
LIVE_TRADING=false
